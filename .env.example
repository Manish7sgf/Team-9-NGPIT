# NVIDIA API Configuration
# ⚠️  NEVER commit the actual .env file with real keys to git
# Create a .env file locally with your real API key

# Your NVIDIA API Key (get from https://build.nvidia.com/api-keys)
VITE_API_KEY=your_nvapi_key_here

# Optional: Proxy server URL (if using backend)
VITE_API_PROXY_URL=http://localhost:3001/api

# Feature flags
VITE_ENABLE_AI_RECOMMENDATIONS=true
VITE_AI_MODEL=nvidia/llama-2-70b-chat
